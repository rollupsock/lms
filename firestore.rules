rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (student, teacher, admin, parent)
    //   - photoURL: string
    //   - createdAt: timestamp
    //   - childrenIds: list (optional, for parents)
    //
    // Collection: courses
    // Document ID: {courseId}
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - teacherId: string (required)
    //   - teacherName: string
    //   - category: string
    //   - thumbnail: string
    //   - createdAt: timestamp
    //
    // Collection: enrollments
    // Document ID: {enrollmentId}
    // Fields:
    //   - studentId: string (required)
    //   - courseId: string (required)
    //   - enrolledAt: timestamp
    //   - progress: number
    //   - status: string (active, completed, dropped)
    //
    // Collection: assignments
    // Document ID: {assignmentId}
    // Fields:
    //   - courseId: string (required)
    //   - title: string (required)
    //   - description: string
    //   - dueDate: timestamp
    //   - maxPoints: number
    //
    // Collection: submissions
    // Document ID: {submissionId}
    // Fields:
    //   - assignmentId: string (required)
    //   - studentId: string (required)
    //   - content: string
    //   - submittedAt: timestamp
    //   - grade: number
    //   - feedback: string
    //
    // Collection: events
    // Document ID: {eventId}
    // Fields:
    //   - title: string (required)
    //   - start: timestamp (required)
    //   - end: timestamp
    //   - type: string (holiday, event, exam)
    //   - description: string
    //
    // Collection: messages
    // Document ID: {messageId}
    // Fields:
    //   - senderId: string (required)
    //   - receiverId: string (required)
    //   - text: string (required)
    //   - createdAt: timestamp
    //   - read: bool
    //
    // Collection: classes
    // Document ID: {classId}
    // Fields:
    //   - name: string (required)
    //   - code: string (required)
    //   - teacherId: string (required)
    //   - createdAt: timestamp
    //
    // Collection: quizzes
    // Document ID: {quizId}
    // Fields:
    //   - courseId: string (required)
    //   - title: string (required)
    //   - description: string
    //   - questions: list (required)
    //   - createdAt: timestamp
    //
    // Collection: comments
    // Document ID: {commentId}
    // Fields:
    //   - courseId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - text: string (required)
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin') || (request.auth.token.email == "mislamat@gmail.com" && request.auth.token.email_verified == true);
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    function isStudent() {
      return hasRole('student');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid is string &&
             data.role in ['student', 'teacher', 'admin', 'parent'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin() || isTeacher() || (isParent() && userId in getUserData().childrenIds));
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || (isTeacher() && request.resource.data.role == 'student'));
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin() || (isTeacher() && resource.data.role == 'student')) && request.resource.data.role == resource.data.role;
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(resource.data.userId));
    }

    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin() || (isTeacher() && resource.data.teacherId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin() || isTeacher() || (isParent() && resource.data.studentId in getUserData().childrenIds));
      allow create: if isAuthenticated() && (isOwner(request.resource.data.studentId) || isAdmin());
      allow update: if isAdmin() || isTeacher();
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin() || isTeacher();
    }

    match /submissions/{submissionId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isAdmin() || isTeacher() || (isParent() && resource.data.studentId in getUserData().childrenIds));
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId);
      allow update: if isAdmin() || isTeacher() || (isOwner(resource.data.studentId) && !('grade' in request.resource.data));
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.senderId) || isOwner(resource.data.receiverId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.senderId);
      allow update: if isAuthenticated() && isOwner(resource.data.receiverId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
